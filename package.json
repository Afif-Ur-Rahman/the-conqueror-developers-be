{
  "name": "conqueror-developers",
  "version": "1.0.0",
  "description": "A Node.js project with TypeScript, MongoDB, and authentication system.",
  "main": "src",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc && tsc-alias",
    "prepare": "husky",
    "lintFix": "npx eslint \"src/**/*.{ts,js}\" --fix",
    "format": "npx prettier --write \"src/**/*.{ts,js,json,md}\"",
    "script": "ts-node -r tsconfig-paths/register scripts/dynamic-executor.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.525.0",
    "@aws-sdk/s3-request-presigner": "^3.525.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "express": "^4.18.3",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "husky": "^9.1.7",
    "inquirer": "^12.9.6",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^16.0.0",
    "module-alias": "^2.2.3",
    "mongoose": "^8.2.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prettier": "^3.5.3",
    "rate-limit-redis": "^4.3.1",
    "sib-api-v3-sdk": "^8.5.0",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^2.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "eslint-plugin-import": "^2.31.0",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "tar": ">=7.5.11",
    "uuid": ">=11.1.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
